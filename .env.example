APP_ENV=local
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=biology_graphrag
POSTGRES_USER=biology_app
POSTGRES_PASSWORD=change_me

NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change_me

QDRANT_URL=http://qdrant:6333

OPENAI_API_KEY=
LLM_PROVIDER=openai

# Named API keys for /admin/* endpoints. Format: "vendor1:key1,vendor2:key2".
# Leave empty to disable auth (safe for local dev; set in any exposed deployment).
ADMIN_API_KEYS=

# Owner-only secret for POST /admin/ingest/run (the token-spending ingest action).
# Empty = locked for everyone. Set to a private value to unlock for yourself only.
INGEST_OWNER_SECRET=
